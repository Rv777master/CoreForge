PORT=5000
MONGO_URI=mongodb://localhost:27017/coreforge

# Optional: enables email notifications when someone submits a form.
# Leave blank to skip email — forms still work and still save to the database.
# EMAIL_USER = a Gmail address you own
# EMAIL_PASS = a Gmail "App Password" (NOT your normal Gmail password — see guide)
# EMAIL_TO   = where notifications should be sent (can be the same as EMAIL_USER)
EMAIL_USER=
EMAIL_PASS=
EMAIL_TO=
